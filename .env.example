# ============================================================
#  whats-middle — configuração
#  Copie este arquivo para ".env" e ajuste os valores.
# ============================================================

# ---- Servidor / Dashboard ----
PORT=3333
HOST=0.0.0.0

# ---- Autenticação do dashboard (SaaS) ----
# AUTH_ENABLED=true exige login na dashboard.
AUTH_ENABLED=true
ADMIN_USER=admin
ADMIN_PASSWORD=admin
# Segredo usado para assinar os tokens de sessão. TROQUE em produção.
SESSION_SECRET=troque-este-segredo
# Validade da sessão em horas
SESSION_TTL_HOURS=72

# ---- API local (/api/v1) para resumos via integração externa ----
# A chave agora é gerada no painel em Configurações → Conexões.
# Esta variável é apenas um fallback inicial opcional (header X-API-Key ou ?api_key=).
API_KEY=

# ---- WhatsApp / open-wa ----
SESSION_ID=whats-middle
# headless=true roda o navegador sem janela (recomendado em servidor).
HEADLESS=true
# Usa o Google Chrome instalado (recomendado pelo open-wa p/ o QR multi-dispositivo).
# Se o Chrome estiver em um caminho não padrão, informe em CHROME_PATH.
USE_CHROME=true
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# User-agent enviado ao WhatsApp Web. O padrão já é um Chrome moderno; só ajuste
# se o QR parar de ser gerado após uma atualização do WhatsApp.
# USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/148.0.0.0 Safari/537.36
# Captura também as mensagens enviadas por você (além das recebidas).
CAPTURE_OUTGOING=true

# ---- Mídia ----
# Baixar e arquivar mídias recebidas (image,video,ptt,audio,document,sticker).
SAVE_MEDIA=true
# Tipos de mídia que devem ser salvos em disco (separados por vírgula).
SAVE_MEDIA_TYPES=image,sticker,ptt,audio,video,document
# Baixar fotos de perfil de contatos e grupos.
SAVE_AVATARS=true

# ---- Logs ----
LOG_LEVEL=info
